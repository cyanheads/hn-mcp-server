{
  "name": "@cyanheads/hn-mcp-server",
  "version": "0.1.8",
  "description": "MCP server for Hacker News — feeds, threads, users, and search via Firebase and Algolia APIs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hn-mcp-server": "dist/index.js"
  },
  "files": ["dist/", "README.md", "LICENSE", "CLAUDE.md", "Dockerfile", "server.json"],
  "scripts": {
    "build": "bun scripts/build.ts",
    "rebuild": "bun scripts/clean.ts && bun scripts/build.ts",
    "clean": "bun scripts/clean.ts",
    "devcheck": "bun scripts/devcheck.ts",
    "tree": "bun scripts/tree.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "bun scripts/lint-mcp.ts",
    "test": "bun --bun vitest run",
    "dev:stdio": "MCP_TRANSPORT_TYPE=stdio bun --watch src/index.ts",
    "dev:http": "MCP_TRANSPORT_TYPE=http bun --watch src/index.ts",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "mcpName": "io.github.cyanheads/hn-mcp-server",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "hacker-news",
    "hn",
    "firebase",
    "algolia"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/hn-mcp-server.git"
  },
  "homepage": "https://github.com/cyanheads/hn-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/cyanheads/hn-mcp-server/issues"
  },
  "author": "cyanheads <casey@caseyjhand.com> (https://github.com/cyanheads/hn-mcp-server#readme)",
  "license": "Apache-2.0",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/cyanheads"
    },
    {
      "type": "buy_me_a_coffee",
      "url": "https://www.buymeacoffee.com/cyanheads"
    }
  ],
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.2",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.2.10",
    "@hono/otel": "^1.1.1",
    "pino-pretty": "^13.1.3"
  },
  "overrides": {
    "path-to-regexp": ">=8.4.0",
    "picomatch": ">=4.0.4",
    "brace-expansion": ">=2.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.0",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}

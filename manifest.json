{
  "manifest_version": "0.3",
  "name": "hn-mcp-server",
  "version": "0.5.9",
  "description": "Browse Hacker News feeds, threads, and user profiles with full-text search via MCP. STDIO or Streamable HTTP.",
  "author": {
    "name": "cyanheads"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cyanheads/hn-mcp-server"
  },
  "homepage": "https://github.com/cyanheads/hn-mcp-server#readme",
  "license": "Apache-2.0",
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/dist/index.js"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "MCP_AUTH_MODE": "none",
        "NODE_ENV": "production",
        "HN_CONCURRENCY_LIMIT": "${HN_CONCURRENCY_LIMIT}",
        "MCP_LOG_LEVEL": "${MCP_LOG_LEVEL}"
      }
    }
  },
  "compatibility": {
    "runtimes": {
      "node": ">=24.0.0"
    }
  },
  "tools_generated": true,
  "prompts_generated": true,
  "user_config": {
    "HN_CONCURRENCY_LIMIT": {
      "title": "Concurrency Limit",
      "description": "Max concurrent HTTP requests for batch item fetches (1–50).",
      "type": "string",
      "required": false,
      "default": "10"
    },
    "MCP_LOG_LEVEL": {
      "title": "Log Level",
      "description": "Minimum log level for output (debug, info, warn, error).",
      "type": "string",
      "required": false,
      "default": "info"
    }
  }
}
